{
    "name": "tclp/markdown-for-agents",
    "description": "Serve Markdown content to AI agents via HTTP content negotiation",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.0",
        "league/html-to-markdown": "^5.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "brianhenryie/strauss": "^0.27"
    },
    "autoload": {
        "psr-4": {
            "Tclp\\WpMarkdownForAgents\\": "src/"
        },
        "classmap": [
            "vendor-prefixed/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tclp\\WpMarkdownForAgents\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "strauss": [
            "vendor/bin/strauss",
            "@composer dump-autoload"
        ],
        "pre-autoload-dump": [
            "@php -r \"if (!is_dir('vendor-prefixed')) { mkdir('vendor-prefixed', 0755, true); }\""
        ],
        "post-install-cmd": [
            "@php -r \"if (file_exists('vendor/bin/strauss')) { passthru('composer strauss', $rc); exit($rc); }\""
        ],
        "post-update-cmd": [
            "@php -r \"if (file_exists('vendor/bin/strauss')) { passthru('composer strauss', $rc); exit($rc); }\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "strauss": {
            "target_directory": "vendor-prefixed",
            "namespace_prefix": "Tclp\\WpMarkdownForAgents\\Vendor\\",
            "classmap_prefix": "Tclp_WpMarkdownForAgents_Vendor_",
            "packages": [
                "league/html-to-markdown"
            ],
            "delete_vendor_packages": true
        }
    }
}
